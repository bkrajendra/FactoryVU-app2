<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <!-- Internal distribution:
       - Set method to "ad-hoc" for Ad Hoc distribution
       - If using Enterprise Program, change method to "enterprise"
  -->
  <key>method</key>
  <string>ad-hoc</string>

  <key>compileBitcode</key>
  <false/>

  <key>stripSwiftSymbols</key>
  <true/>

  <key>destination</key>
  <string>export</string>

  <!-- Leave signingStyle as automatic if your profile matches the bundle id.
       If you use manual signing in CI, set "manual" and provide more keys. -->
  <key>signingStyle</key>
  <string>automatic</string>

  <!-- Optional: if you want to force a team, set your Team ID -->
  <!--
  <key>teamID</key>
  <string>REPLACE_TEAM_ID</string>
  -->
</dict>
</plist>

